{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ],
    "deny": []
  },
  "mcpServers": {
    "meta-ads": {
      "command": "python3",
      "args": ["mcp/meta-ads-server/server.py"],
      "env": {
        "META_ACCESS_TOKEN": "",
        "META_AD_ACCOUNT_ID": "",
        "META_PAGE_ID": "",
        "META_INSTAGRAM_ACCOUNT_ID": "",
        "META_APP_ID": "",
        "META_APP_SECRET": ""
      }
    }
  }
}
